# =============================================================================
# DevSearch — Environment Variables
# Copy this file to .env and fill in your values. Never commit the .env file.
# =============================================================================

# ---------------------------------------------------------------------------
# Core Django
# ---------------------------------------------------------------------------

SECRET_KEY=your-secret-key-here-generate-with-python-secrets-token-hex-50
DEBUG=True

# Comma-separated list of allowed hosts.
# Development default (in dev settings): *  (any host — convenient for 0.0.0.0 and LAN testing)
# You can still set this if you want to be restrictive:
# ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# The public-facing URL of this site — used to build absolute URLs in emails
# (e.g. the unsubscribe link in notification emails).
# Development default: http://127.0.0.1:8000
# Production example: https://yourdomain.com
SITE_URL=http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# Database (SQLite is the default for development — no config needed)
# Production PostgreSQL (only required when DEBUG=False):
# ---------------------------------------------------------------------------

DB_NAME=your_postgres_db_name
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password
DB_HOST=your_postgres_host
DB_PORT=5432

# Schema name for isolating tables when sharing one PostgreSQL instance
# across multiple projects (each project gets its own schema).
DB_SCHEMA=devsearch

# ---------------------------------------------------------------------------
# Email — Development (Mailtrap Sandbox SMTP)
# Sign up at https://mailtrap.io, create a sandbox inbox, and copy the SMTP
# credentials from the "SMTP" tab (not the API tab).
# ---------------------------------------------------------------------------

DEV_EMAIL_HOST=sandbox.smtp.mailtrap.io
DEV_EMAIL_USER=your_mailtrap_smtp_username
DEV_EMAIL_PASSWORD=your_mailtrap_smtp_password
DEV_EMAIL_PORT=25
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=hello@yourdomain.com

# ---------------------------------------------------------------------------
# Email — Production (e.g. Gmail, SendGrid, Mailgun)
# Only required when DEBUG=False.
# ---------------------------------------------------------------------------

EMAIL_HOST=smtp.gmail.com
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_app_password_or_api_key
EMAIL_PORT=587

# ---------------------------------------------------------------------------
# GitHub OAuth (django-allauth)
# Create an OAuth App at https://github.com/settings/developers
# Callback URL (dev): http://127.0.0.1:8000/accounts/github/login/callback/
# Callback URL (prod): https://yourdomain.com/accounts/github/login/callback/
# ---------------------------------------------------------------------------

GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret